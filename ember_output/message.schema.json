{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"title": "World Message",
	"description": "A schema that validates world message JSON inputs",
	"required": [
		"name",
		"opcode",
		"direction"
	],
	"type": "object",
	"properties": {
		"name": {
			"type": "string",
			"pattern": "^[A-Z][A-Za-z0-9]*$",
			"description": "PascalCase class name for the generated packet struct (e.g. LoginVerifyWorld)"
		},
		"opcode": {
			"type": "string",
			"pattern": "^(cmsg|smsg|msg)_[a-z0-9_]+$",
			"description": "Wire opcode identifier in snake_case (e.g. smsg_login_verify_world)"
		},
		"direction": {
			"type": "string",
			"enum": ["client", "server"],
			"description": "Packet direction — 'client' = sent from client to server, 'server' = sent from server to client"
		},
		"fields": {
			"$ref": "#/$defs/fields"
		}
	},
	"additionalProperties": false,
	"$defs": {
		"field_type": {
			"type": "string",
			"description": "A built-in primitive or the name of a custom type declared in types.json",
			"anyOf": [
				{
					"enum": [
						"uint8",
						"uint16",
						"uint32",
						"uint64",
						"int8",
						"int16",
						"int32",
						"int64",
						"float",
						"double"
					]
				},
				{
					"pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
				}
			]
		},
		"fields": {
			"type": "array",
			"items": {
				"oneOf": [
					{ "$ref": "#/$defs/field" },
					{ "$ref": "#/$defs/group" },
					{ "$ref": "#/$defs/if_chain" }
				]
			},
			"minItems": 1,
			"uniqueItems": true
		},
		"field": {
			"type": "object",
			"properties": {
				"name": {
					"type": "string"
				},
				"type": {
					"$ref": "#/$defs/field_type"
				},
				"as": {
					"type": "string",
					"description": "Semantic type exposed in the generated struct. The on-wire representation is still `type`; reads/writes cast between the two. Must be a declared enum/flags whose underlying matches `type` OR a declared struct whose layout is equivalent.",
					"pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
				},
				"when": {
					"$ref": "#/$defs/condition"
				},
				"array": {
					"$ref": "#/$defs/array"
				}
			},
			"required": ["name", "type"],
			"additionalProperties": false
		},
		"array": {
			"type": "object",
			"description": "Marks the field as a fixed-size array (size), a dynamic vector sized by a prior field (count_field), or an unbounded vector read until the stream is drained (until_end).",
			"properties": {
				"size":        { "type": "integer", "minimum": 1 },
				"count_field": { "type": "string" },
				"until_end":   { "const": true }
			},
			"additionalProperties": false,
			"oneOf": [
				{ "required": ["size"],        "not": { "anyOf": [ { "required": ["count_field"] }, { "required": ["until_end"] } ] } },
				{ "required": ["count_field"], "not": { "anyOf": [ { "required": ["size"] },        { "required": ["until_end"] } ] } },
				{ "required": ["until_end"],   "not": { "anyOf": [ { "required": ["size"] },        { "required": ["count_field"] } ] } }
			]
		},
		"group": {
			"type": "object",
			"description": "A block of fields that are serialised together when `when` evaluates true",
			"properties": {
				"type": {
					"const": "group"
				},
				"when": {
					"$ref": "#/$defs/condition"
				},
				"fields": {
					"$ref": "#/$defs/fields"
				}
			},
			"required": ["type", "fields"],
			"additionalProperties": false
		},
		"if_chain": {
			"type": "object",
			"description": "if / else-if / else cascade. Branches are evaluated in order; the first `when` that matches selects a body. The optional `else` body runs when none of the branches matched. Semantically identical to a sequence of `group` entries, but the generator emits `if / else if / else` instead of independent `if` blocks (clearer code and one compile-time check per chain).",
			"properties": {
				"type":     { "const": "if_chain" },
				"branches": {
					"type": "array",
					"minItems": 1,
					"items": {
						"type": "object",
						"required": ["when", "fields"],
						"additionalProperties": false,
						"properties": {
							"when":   { "$ref": "#/$defs/condition" },
							"fields": { "$ref": "#/$defs/fields" }
						}
					}
				},
				"else":     { "$ref": "#/$defs/fields" }
			},
			"required": ["type", "branches"],
			"additionalProperties": false
		},
		"value_ref": {
			"type": "object",
			"description": "Right-hand side of a comparison referring to another prior field (optionally negated with `!`)",
			"properties": {
				"field":  { "type": "string" },
				"negate": { "type": "boolean" }
			},
			"required": ["field"],
			"additionalProperties": false
		},
		"condition": {
			"type": "object",
			"description": "A predicate that gates serialisation. Leaf ops (`eq`, `neq`, `in`, `has_flag`, `empty`) test a prior field; `stream_not_empty` tests runtime stream state (read-only — the write path emits the fields unconditionally); `and`/`or`/`not` compose other conditions.",
			"properties": {
				"op": {
					"type": "string",
					"enum": ["eq", "neq", "in", "has_flag", "empty", "stream_not_empty", "and", "or", "not"]
				},
				"field": {
					"type": "string",
					"description": "Name of a prior field in the same message whose value is tested"
				},
				"value": {},
				"conditions": {
					"type": "array",
					"description": "Subconditions combined by `and`/`or`",
					"items": { "$ref": "#/$defs/condition" },
					"minItems": 1
				},
				"condition": {
					"description": "Single inner condition for `not`",
					"$ref": "#/$defs/condition"
				}
			},
			"required": ["op"],
			"additionalProperties": false,
			"allOf": [
				{
					"if":   { "properties": { "op": { "enum": ["eq", "neq", "in", "has_flag"] } }, "required": ["op"] },
					"then": { "required": ["field", "value"] }
				},
				{
					"if":   { "properties": { "op": { "const": "empty" } }, "required": ["op"] },
					"then": {
						"required": ["field"],
						"not": {
							"anyOf": [
								{ "required": ["value"] },
								{ "required": ["conditions"] },
								{ "required": ["condition"] }
							]
						}
					}
				},
				{
					"if":   { "properties": { "op": { "const": "stream_not_empty" } }, "required": ["op"] },
					"then": {
						"not": {
							"anyOf": [
								{ "required": ["field"] },
								{ "required": ["value"] },
								{ "required": ["conditions"] },
								{ "required": ["condition"] }
							]
						}
					}
				},
				{
					"if":   { "properties": { "op": { "const": "in" } }, "required": ["op"] },
					"then": {
						"properties": {
							"value": {
								"type": "array",
								"minItems": 1,
								"items": { "type": ["integer", "string"] }
							}
						}
					}
				},
				{
					"if":   { "properties": { "op": { "const": "has_flag" } }, "required": ["op"] },
					"then": { "properties": { "value": { "type": ["integer", "string"] } } }
				},
				{
					"if":   { "properties": { "op": { "enum": ["eq", "neq"] } }, "required": ["op"] },
					"then": {
						"properties": {
							"value": {
								"oneOf": [
									{ "type": "integer" },
									{ "type": "string" },
									{ "$ref": "#/$defs/value_ref" }
								]
							}
						}
					}
				},
				{
					"if":   { "properties": { "op": { "enum": ["and", "or"] } }, "required": ["op"] },
					"then": {
						"required": ["conditions"],
						"not": {
							"anyOf": [
								{ "required": ["field"] },
								{ "required": ["value"] },
								{ "required": ["condition"] }
							]
						}
					}
				},
				{
					"if":   { "properties": { "op": { "const": "not" } }, "required": ["op"] },
					"then": {
						"required": ["condition"],
						"not": {
							"anyOf": [
								{ "required": ["field"] },
								{ "required": ["value"] },
								{ "required": ["conditions"] }
							]
						}
					}
				}
			]
		}
	}
}
