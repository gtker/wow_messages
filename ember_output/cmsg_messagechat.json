{
  "name": "Messagechat",
  "opcode": "cmsg_messagechat",
  "direction": "client",
  "fields": [
    {
      "name": "chat_type",
      "type": "ChatType",
      "as": "uint32"
    },
    {
      "name": "language",
      "type": "Language"
    },
    {
      "type": "if_chain",
      "branches": [
        {
          "when": {
            "op": "eq",
            "field": "chat_type",
            "value": "WHISPER"
          },
          "fields": [
            {
              "name": "target_player",
              "type": "CString"
            }
          ]
        },
        {
          "when": {
            "op": "eq",
            "field": "chat_type",
            "value": "CHANNEL"
          },
          "fields": [
            {
              "name": "channel",
              "type": "CString"
            }
          ]
        }
      ]
    },
    {
      "name": "message",
      "type": "CString"
    }
  ]
}