{
  "name": "LootResponse",
  "opcode": "smsg_loot_response",
  "direction": "server",
  "fields": [
    {
      "name": "guid",
      "type": "uint64"
    },
    {
      "name": "loot_method",
      "type": "LootMethod"
    },
    {
      "type": "if_chain",
      "branches": [
        {
          "when": {
            "op": "eq",
            "field": "loot_method",
            "value": "ERROR"
          },
          "fields": [
            {
              "name": "loot_error",
              "type": "LootMethodError"
            }
          ]
        }
      ]
    },
    {
      "name": "gold",
      "type": "Gold"
    },
    {
      "name": "amount_of_items",
      "type": "uint8"
    },
    {
      "name": "items",
      "type": "LootItem",
      "array": {
        "count_field": "amount_of_items"
      }
    }
  ]
}